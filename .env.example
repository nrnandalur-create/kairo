# ─────────────────────────────────────────────────────────────────────────────
# Kairo — environment variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Finnhub API key (free tier)
# Get yours at: https://finnhub.io → Dashboard → API Keys
# Used for: real-time price quotes, company profiles, financials, candle data
# Prefix VITE_ so Vite exposes it to the browser bundle
VITE_FINNHUB_API_KEY=your_finnhub_api_key_here

# Anthropic API key (Claude)
# Get yours at: https://console.anthropic.com → API Keys
# Used server-side only in /api/analyze.js — never sent to the browser
# Required for AI analysis, candle pattern detection, and trade ideas
ANTHROPIC_API_KEY=your_anthropic_api_key_here
