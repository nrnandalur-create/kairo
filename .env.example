# ─────────────────────────────────────────────────────────────────────────────
# Kairo — environment variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# All keys are server-side only — none are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Finnhub API key (free tier) — quote, company profile, fundamentals, news
# Get yours at: https://finnhub.io → Dashboard → API Keys
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API key (free tier) — daily OHLCV candle history
# Get yours at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day. Falls back to synthetic candles if unavailable.
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Groq API key — server-side AI analysis via /api/analyze
# Get yours at: https://console.groq.com → API Keys
# Model: llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here
