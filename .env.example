# ─────────────────────────────────────────────────────────────────────────────
# Kairo — environment variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Finnhub API key (free tier) — quote, company profile, fundamentals
# Get yours at: https://finnhub.io → Dashboard → API Keys
# Used server-side only in /api/market.js — never sent to the browser
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage API key (free tier) — 30-day daily OHLCV candle data
# Get yours at: https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 5/min. Falls back to synthetic candles if unavailable.
# Used server-side only in /api/market.js — never sent to the browser
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Groq API key — called directly from the browser
# Get yours at: https://console.groq.com → API Keys
# Required for AI analysis, candle pattern detection, and trade ideas
# Model: llama3-8b-8192 (free tier available)
VITE_GROQ_API_KEY=your_groq_api_key_here
